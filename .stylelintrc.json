{
  "extends": "stylelint-config-standard",
  "plugins": ["stylelint-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "apply",
          "layer",
          "theme",
          "custom-variant",
          "import",
          "font-face"
        ]
      }
    ]
  }
}
